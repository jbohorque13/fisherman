{
  "expo": {
    "name": "Fisherman",
    "slug": "fisherman",
    "version": "1.0.0",
    "scheme": "fisherman",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.josue.fisherman.app",
      "userInterfaceStyle": "automatic",
      "runtimeVersion": "1.0.0",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.josue.fisherman.app",
      "softwareKeyboardLayoutMode": "pan",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "fisherman"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "runtimeVersion": "1.0.0"
    },
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563EB",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Fisherman necesita acceso a tus fotos para actualizar tu foto de perfil.",
          "cameraPermission": "Fisherman necesita acceso a tu cámara para tomar una foto de perfil.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "46906f44-092f-4ffb-bc20-1bcf92ea91ae"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/46906f44-092f-4ffb-bc20-1bcf92ea91ae"
    }
  }
}
